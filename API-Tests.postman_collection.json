        {
          "name": "Fetch User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is acceptable\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
                  "});\r",
                  "\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"User ID is 1\", function () {\r",
                  "    pm.expect(jsonData.id).to.eql(1);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has required fields\", function () {\r",
                  "    pm.expect(jsonData).to.have.property('id');\r",
                  "    pm.expect(jsonData).to.have.property('firstName');\r",
                  "    pm.expect(jsonData).to.have.property('lastName');\r",
                  "    pm.expect(jsonData).to.have.property('email');\r",
                  "    pm.expect(jsonData).to.have.property('age');\r",
                  "});\r",
                  "\r",
                  "const schema = {\r",
                  "    type: \"object\",\r",
                  "    required: [\"id\", \"firstName\", \"lastName\", \"email\", \"age\", \"phone\", \"address\"],\r",
                  "    properties: {\r",
                  "        id:        { type: \"integer\" },\r",
                  "        firstName: { type: \"string\" },\r",
                  "        lastName:  { type: \"string\" },\r",
                  "        email:     { type: \"string\" },\r",
                  "        age:       { type: \"integer\" },\r",
                  "        phone:     { type: \"string\" },\r",
                  "        gender:    { type: \"string\" },\r",
                  "        birthDate: { type: \"string\" },\r",
                  "        address: { type:\r",
                  "        \"object\" }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Schema validation passes\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(tv4.validate(jsonData, schema)).to.be.true;\r",
                  "});\r",
                  "\r",
                  "const savedToken = pm.environment.get(\"accessToken\");\r",
                  "pm.test(\"Access token is available in environment\", function () {\r",
                  "    pm.expect(savedToken).to.not.be.undefined;\r",
                  "    pm.expect(savedToken).to.not.be.empty;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
