    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is acceptable\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
                  "});\r",
                  "\r",
                  "const jsonData= pm.response.json()\r",
                  "pm.test(\"Access token is present\", ()=>{\r",
                  "    pm.expect(jsonData).to.have.property('accessToken');\r",
                  "    pm.expect(jsonData.accessToken).to.be.a('string');\r",
                  "})\r",
                  "\r",
                  "pm.environment.set(\"accessToken\", jsonData.accessToken);\r",
                  "pm.test(\"Token saved to environment\", ()=>{\r",
                  "    pm.expect(pm.environment.get(\"accessToken\")).to.not.be.empty;\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Username matches\", ()=>{\r",
                  "    pm.expect(jsonData.username).to.eql(pm.iterationData.get(\"loginUsername\"));\r",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"{{loginUsername}}\",\r\n    \"password\": \"{{loginPassword}}\",\r\n    \"expiresInMins\": 30\r\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
